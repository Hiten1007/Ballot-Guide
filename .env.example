# ─── BallotGuide Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in your API keys

# Server Configuration
NODE_ENV=development
PORT=3000

# Google Gemini AI API Key (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Civic Information API Key (https://console.cloud.google.com/)
GOOGLE_CIVIC_API_KEY=your_civic_api_key_here

# Google Cloud API Key for Translate & TTS (https://console.cloud.google.com/)
GOOGLE_CLOUD_API_KEY=your_cloud_api_key_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
