{
  "name": "ballot-guide",
  "version": "1.0.0",
  "description": "An AI-powered interactive election process education assistant built with Google Services",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --detectOpenHandles",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --forceExit --detectOpenHandles",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/unit --forceExit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/integration --forceExit --detectOpenHandles",
    "lint": "eslint src/ server.js --ext .js",
    "lint:fix": "eslint src/ server.js --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" server.js",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" server.js"
  },
  "keywords": [
    "election",
    "civic-education",
    "google-gemini",
    "ai-assistant",
    "voter-guide",
    "google-services"
  ],
  "author": "Hiten",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "sanitize-html": "^2.14.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^50.6.3",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
